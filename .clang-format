# 本项目自有代码格式规范 (PRD §2.2): Google C++ Style.
# 仅作用于 src/ —— third_party/ 下另有 .clang-format 设置 DisableFormat: true,
# 避免误格式化开源库源码 (PRD §15.7)。
---
Language:        Cpp
BasedOnStyle:    Google
Standard:        c++17
# 团队统一放宽到 100 列 (PRD §2.2: 80, 团队可统一放宽到 100, 须一致)。
ColumnLimit:     100
IndentWidth:     2
TabWidth:        2
UseTab:          Never
DerivePointerAlignment: false
PointerAlignment: Left
SortIncludes:    true
...
